# Optional keys for seed probe scripts (scripts/probe-apikey-batch.mjs, scripts/probe-all-candidates.mjs).
# Copy to .env and fill in — OMDb works without any keys (public patron key `trilogy`).

TMDB_API_KEY=
FANART_API_KEY=
TVDB_API_KEY=
TRAKT_CLIENT_ID=
LASTFM_API_KEY=
WATCHMODE_API_KEY=
RAWG_API_KEY=
TWITCH_CLIENT_ID=
COMICVINE_API_KEY=

TURNSTILE_SECRET_KEY=
TURNSTILE_SITEKEY=

# Public GA4 measurement ID (G-XXXXXXXX). Also set in wrangler vars / secrets for production.
# Leave blank locally to skip the gtag scripts (Cloudflare beacon still loads).
GA_MEASUREMENT_ID=